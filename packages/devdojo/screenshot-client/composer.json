{
    "name": "devdojo/screenshot-client",
    "description": "A fluent Laravel client for the DevDojo screenshot service.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "DevDojo\\ScreenshotClient\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevDojo\\ScreenshotClient\\ScreenshotServiceProvider"
            ],
            "aliases": {
                "Screenshot": "DevDojo\\ScreenshotClient\\Facades\\Screenshot"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
